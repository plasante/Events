<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE validators PUBLIC
"-//OpenSymphony Group//XWork Validator 1.0.2//EN"
"http://struts.apache.org/dtds/xwork-validator-1.0.2.dtd">
  
<validators>
	<field name="username">
		<field-validator type="requiredstring">
			<param name="trim">true</param>
			<message key="global.username_is_required" />
		</field-validator>
		<field-validator type="regex">
			<param name="regexExpression">
				<![CDATA[[a-zA-Z0-9_]+]]>
			</param>
			<message key="global.username_contains_invalid_characters" />
		</field-validator>
		<field-validator type="stringlength">
			<param name="minLength">6</param>
			<param name="maxLength">20</param>
			<message key="global.username_invalid_length" />
		</field-validator>
	</field>
	
	<field name="password">
		<field-validator type="requiredstring">
			<param name="trim">true</param>
			<message>Password is required</message>
		</field-validator>
		<field-validator type="regex">
			<param name="regexExpression">
				<![CDATA[[a-zA-Z0-9_]+]]>
			</param>
			<message>Password contains invalid characters</message>
		</field-validator>
		<field-validator type="stringlength">
			<param name="minLength">6</param>
			<param name="maxLength">20</param>
			<message>Password needs to be 6 to 20 characters long</message>
		</field-validator>
	</field>
</validators>